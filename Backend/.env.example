# Backend Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit your .env file to version control

# ============================================
# SERVER CONFIGURATION
# ============================================

# Port on which the backend server runs
PORT=5000

# ============================================
# DATABASE
# ============================================

# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
MONGO_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/mediflow

# ============================================
# AUTHENTICATION
# ============================================

# JWT Secret key — must be a strong, random string (minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_strong_jwt_secret_key_minimum_32_characters_here

# ============================================
# CORS
# ============================================

# URL of your frontend application (no trailing slash)
# Development: http://localhost:5174
# Production:  https://your-frontend.vercel.app
CLIENT_URL=http://localhost:5174

# ============================================
# EMAIL — RESEND
# ============================================

# Email (Resend)
# The address emails are sent FROM (must match your verified Resend domain)
EMAIL_USER=noreply@yourdomain.com

# Reply-to address — users who reply will reach this inbox.
# Using a real monitored address improves sender reputation.
EMAIL_REPLY_TO=support@yourdomain.com

# Support address shown in the email footer (CAN-SPAM requirement)
SUPPORT_EMAIL=support@yourdomain.com

# Resend API Key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# AI — GOOGLE GEMINI
# ============================================

# Gemini API Key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# GOOGLE CALENDAR API
# ============================================

# OAuth 2.0 Client ID from Google Cloud Console
# (APIs & Services → Credentials → OAuth 2.0 Client IDs)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# OAuth 2.0 Client Secret
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret_here

# Redirect URI — must match what is registered in Google Cloud Console
# Development: http://localhost:5000/auth/google/callback
# Production:  https://your-backend.onrender.com/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# Refresh Token for server-to-server Calendar access
# Generated once using OAuth 2.0 authorization flow with calendar scope
# See DEPLOYMENT_GUIDE.md → Section 3 for instructions
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here
